default_platform(:android)

platform :android do
  desc "Run Lint, Unit Tests, and deploy the Dev Debug APK to Firebase App Distribution"
  lane :deploy_debug_to_firebase do
    # 1. Clear old cache artifacts and run structural code analysis on the explicit dev variant
    gradle(tasks: ["clean", "lintDevDebug"])

    # 2. Run your unit test suite for the dev flavor
    gradle(task: "testDevDebugUnitTest")

    # 3. Compile the flavor-specific debug binary artifact
    gradle(task: "assembleDevDebug")

    # 4. Push cleanly to your testers via Firebase
    firebase_app_distribution(
      # 🌟 FIXED: Hardcoding your Dev App ID here ensures Fastlane uploads directly to your '.dev' container
      app: "1:960077749649:android:660905a62bb089cbcd4e30",
      groups: "testers", # 🔥 Keeps your exact group name intact
      apk_path: "app/build/outputs/apk/dev/debug/app-dev-debug.apk",
      release_notes: "Automated Build via Fastlane flavor integration"
    )
  end
end